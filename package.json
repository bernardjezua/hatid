{
  "name": "hatid-marketplace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "server": "pnpm run dev --prefix server",
    "client": "pnpm run start --prefix client",
    "install-all": "pnpm install && pnpm install --prefix server && pnpm install --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
